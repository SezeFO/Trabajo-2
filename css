body {
    background-image: url(images/BossClean.jpg);
    font-family: Arial, sans-serif;
   
    background-repeat: no-repeat;   
    background-size: cover;
    background-attachment: fixed;
}

/* desde esta parte */
.check-logic {
  display: none;
}

.mi-boton img {
    border: 3px solid #48ff00;
  cursor: pointer;
  transition: transform 0.2s;
  display: block;
}

.mi-boton img:hover {
  filter: brightness(1.2);
}

.foto {
  width: 100%;
  max-width: 500px;
  height: auto;
}

.final {
  display: none;
}

#disparador:checked ~ header .galeria .inicial {
  display: none;
}

#disparador:checked ~ header .galeria .final {
  display: block;
}

#disparador:checked ~ #empleados .galeria .inicial {
  display: none;
}

#disparador:checked ~ #empleados .galeria .final {
  display: block;
}

/* le pedi a la ia para saber como se hacia los botones interactivos */

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

section img {
    max-width: 30%;
}

nav ul {
    display: flex;
    list-style: none;
    gap: 15px;
}

nav a {
    text-decoration: none;
    color: #ffffff;
}

.hero {
    border: 4px solid #7a7979;
    background-image: url("images/Event2.png");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;   
    background-size: cover;
    background-attachment: fixed;
    color: white;
    padding: 66px 20px;
}

.cards {
    display: flex;
    gap: 30px;
    padding: 20px;
}

.card {
    border: 3px solid #8f8d8d;
    color: white;
    padding: 5px;
    width: 900px;
}

.card1 {
    border: 3px solid #8f8d8d;
    color: white;
    width: 1300px;
 }

#contactos{
    color: white;
    padding: 20px;
}

#empleados {
    border: 3px solid #8f8d8d;
    color: white;
    padding: 20px;
}
#empleado {

    color: white;
    padding: 20px;
}
.empleados-container {
    display: flex;
    gap: 20px;
}

.empleados-container article {

    width: 700px;
}

#empleados article header .galeria {
      display: flex;
    width: 150px;
}

#info {
    color: white;
    padding: 20px;
}

.info-container {
    display: flex;
    gap: 20px;
}

.info-items {
    display: flex;
    gap: 15px;
}

.info-items img {
    width: 300px;
    height: 80px;
    border-radius: 50%;
}

footer {
    color: white;   
    text-align: center;
    padding: 15px;
    border-top: 1px solid #ccc;
}
